# Optional official filings/news and scheduled digest support.
SEC_USER_AGENT="FolioCore/0.1 contact@example.com"
CRON_SECRET=""
DIGEST_EMAIL_RECIPIENTS=""
CRON_REFRESH_EMAILS=""

# Simple single-user auth placeholder for the MVP.
